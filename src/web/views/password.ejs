<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>비밀번호 변경 · MySQL Backup Manager</title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <header class="topbar">
      <div>
        <h1>비밀번호 변경</h1>
        <p>로그인 계정 <strong><%= currentUser %></strong></p>
      </div>
      <nav class="top-actions" aria-label="계정 및 작업">
        <a class="button" href="/">목록</a>
        <form method="post" action="/logout">
          <button class="button" type="submit">로그아웃</button>
        </form>
      </nav>
    </header>

    <main class="container narrow">
      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>
      <% if (errors.length > 0) { %>
        <div class="notice danger">
          <% errors.forEach((error) => { %>
            <div><%= error %></div>
          <% }) %>
        </div>
      <% } %>

      <form class="form-grid" method="post" action="/password" autocomplete="off">
        <label>
          현재 비밀번호
          <input name="currentPassword" type="password" required autocomplete="current-password">
        </label>

        <label>
          변경할 비밀번호
          <input name="nextPassword" type="password" minlength="8" required autocomplete="new-password">
        </label>

        <label>
          변경할 비밀번호 확인
          <input name="confirmPassword" type="password" minlength="8" required autocomplete="new-password">
        </label>

        <div class="form-actions">
          <a class="button" href="/">취소</a>
          <button class="button primary" type="submit">변경</button>
        </div>
      </form>
    </main>
  </body>
</html>

