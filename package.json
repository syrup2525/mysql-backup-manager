{
  "name": "mysql-backup-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "start": "node dist/web/server.js",
    "backup": "node dist/cli/backup-runner.js",
    "dev": "tsx src/web/server.ts",
    "dev:backup": "tsx src/cli/backup-runner.ts"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "fastify": "^5.2.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.11.0"
  }
}
